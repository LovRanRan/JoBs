# Postgres 连接串(本地或 Neon/Supabase 等托管)
DATABASE_URL="postgresql://user:password@localhost:5432/jobs?schema=public"

# 会话签名密钥(生成:openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API(按 JD 改简历)。不填则用模板回退。
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# 每日抓取 cron 的校验密钥(Vercel Cron 会带 Authorization: Bearer <CRON_SECRET>)
CRON_SECRET="change-me-too"
