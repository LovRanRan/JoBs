generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  profile      Profile?
  applications Application[]
  resumes      Resume[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  yearsExp        Int      @default(0)
  location        String?
  targetRoles     String[]
  targetLocations String[]
  minSalary       Int      @default(0)
  workAuth        String?
  skills          String[]
}

model Job {
  id           String        @id @default(cuid())
  title        String
  company      String
  location     String
  remote       Boolean       @default(false)
  salary       String?
  source       String        // greenhouse | lever | ashby | manual
  externalId   String?       // id from the ATS, for dedup
  postedAt     DateTime
  tags         String[]
  jdSummary    String
  jdFull       String?
  url          String
  createdAt    DateTime      @default(now())
  applications Application[]

  @@unique([source, externalId])
}

model Application {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage      String    @default("new") // new|to_apply|applied|oa|interview|offer|closed
  appliedAt  DateTime?
  contact    String?
  nextStep   String?
  resumeId   String?
  matchScore Int       @default(0)
  matched    String[]
  gaps       String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, jobId])
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  base        Boolean  @default(false)
  tailoredFor String?
  keywords    String[]
  content     String?
  updatedAt   DateTime @default(now()) @updatedAt
}
