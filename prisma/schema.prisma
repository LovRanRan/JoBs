generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  name         String?
  createdAt    DateTime         @default(now())
  profile      Profile?
  applications Application[]
  resumes      Resume[]
  autoApply    AutoApplyConfig?
  apiTokens    ApiToken[]
  logs         ApplicationLog[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  yearsExp        Int      @default(0)
  location        String?
  targetRoles     String[]
  targetLocations String[]
  minSalary       Int      @default(0)
  workAuth        String?
  skills          String[]
}

model Job {
  id           String        @id @default(cuid())
  title        String
  company      String
  location     String
  remote       Boolean       @default(false)
  salary       String?
  source       String        // greenhouse | lever | ashby | manual
  externalId   String?       // id from the ATS, for dedup
  postedAt     DateTime
  tags         String[]
  jdSummary    String
  jdFull       String?
  url          String
  createdAt    DateTime      @default(now())
  applications Application[]

  @@unique([source, externalId])
}

model Application {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage      String    @default("new") // new|to_apply|applied|oa|interview|offer|closed
  appliedAt  DateTime?
  contact    String?
  nextStep   String?
  resumeId   String?
  matchScore Int       @default(0)
  matched    String[]
  gaps       String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, jobId])
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  base        Boolean  @default(false)
  tailoredFor String?
  keywords    String[]
  content     String?
  updatedAt   DateTime @default(now()) @updatedAt
}

// ---- 自动投递相关 ----

model AutoApplyConfig {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled        Boolean  @default(false)
  dailyLimit     Int?     // null = 不限(由用户手动设置)
  platforms      String[] @default(["greenhouse", "lever", "ashby"])
  dryRun         Boolean  @default(true)
  minIntervalSec Int      @default(45)
  updatedAt      DateTime @default(now()) @updatedAt
}

// 插件每次投递的结果回写
model ApplicationLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String?
  company       String
  title         String
  platform      String
  status        String   // filled | submitted | failed | skipped
  message       String?
  screenshotUrl String?
  createdAt     DateTime @default(now())
}

// 浏览器插件鉴权用(存 hash,原文仅创建时返回一次)
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  prefix     String
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}
